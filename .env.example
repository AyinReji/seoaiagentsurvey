# ============================================================================
# SEO Survey Platform — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#
# IMPORTANT:
# - Variables prefixed with VITE_ are exposed to the client bundle
# - Variables WITHOUT VITE_ prefix are server-only (never sent to browser)
# - Never commit your .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Firebase Client SDK (VITE_ prefix = client-safe, embedded in browser bundle)
# ----------------------------------------------------------------------------
# These values are NOT secrets — Firebase security is enforced by Firestore
# Security Rules, not by hiding the API key.
#
# WHERE TO FIND THESE VALUES:
# 1. Go to https://console.firebase.google.com
# 2. Select your project (or create one)
# 3. Click the gear icon → "Project settings"
# 4. Scroll to "Your apps" section
# 5. If no web app exists, click "Add app" → Web (</>)
# 6. Copy the config values from the firebaseConfig object
# ----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Example values (do NOT use these — they are placeholders):
# VITE_FIREBASE_API_KEY=AIzaSyC1234567890abcdefghijklmnop
# VITE_FIREBASE_AUTH_DOMAIN=my-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=my-project
# VITE_FIREBASE_STORAGE_BUCKET=my-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ----------------------------------------------------------------------------
# Firebase Admin SDK (server-only — NO VITE_ prefix)
# ----------------------------------------------------------------------------
# Used for secure server-side operations if needed in the future.
# Currently not required — the survey uses client-side Firestore writes
# secured by Firestore Security Rules.
#
# WHERE TO FIND THESE VALUES:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Click gear icon → "Project settings" → "Service accounts" tab
# 4. Click "Generate new private key"
# 5. Download the JSON file
# 6. Copy the values below from the downloaded JSON
#
# IMPORTANT — PRIVATE KEY FORMATTING:
# The private key contains newlines. In .env files, wrap it in double quotes
# and keep the literal \n characters:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# In deployment platforms (Vercel/Netlify), paste the entire key including
# the BEGIN/END markers. The platform handles escaping.
# ----------------------------------------------------------------------------

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Email Notifications via Resend (server-only)
# ----------------------------------------------------------------------------
# Resend sends admin email notifications when a survey is submitted.
#
# SETUP STEPS:
# 1. Sign up at https://resend.com/signup
# 2. Create an API key at https://resend.com/api-keys
# 3. Verify your sending domain at https://resend.com/domains
#    (or use onboarding@resend.dev for testing)
# 4. Set EMAIL_TO to the admin email that should receive notifications
#
# If these are not set, the app works normally — emails are just skipped
# and logged to the server console instead.
# ----------------------------------------------------------------------------

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=

# Example:
# RESEND_API_KEY=re_1234567890abcdef
# EMAIL_FROM=survey@yourdomain.com
# EMAIL_TO=admin@yourdomain.com

# ----------------------------------------------------------------------------
# Public App Configuration (Client-side)
# ----------------------------------------------------------------------------
# VITE_APP_NAME specifies the public brand name of the app if needed
# VITE_WHATSAPP_URL specifies the WhatsApp contact link for the contact modal
# VITE_LINKEDIN_URL specifies the LinkedIn profile link for the footer & contact modal
# ----------------------------------------------------------------------------

VITE_APP_NAME=SEO Survey Platform
VITE_WHATSAPP_URL=
VITE_LINKEDIN_URL=
